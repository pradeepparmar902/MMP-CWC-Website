<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Firebase Firestore & Storage -->
        <domain includeSubdomains="true">firebaseio.com</domain>
        <domain includeSubdomains="true">firestore.googleapis.com</domain>
        <domain includeSubdomains="true">firebasestorage.googleapis.com</domain>
        <domain includeSubdomains="true">firebase.googleapis.com</domain>
        <!-- Google Drive (for banner images) -->
        <domain includeSubdomains="true">drive.google.com</domain>
        <domain includeSubdomains="true">lh3.googleusercontent.com</domain>
        <domain includeSubdomains="true">googleusercontent.com</domain>
        <!-- General googleapis -->
        <domain includeSubdomains="true">googleapis.com</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
